<div class="tab-scroll combat-tab npc-combat-tab">
  <section class="equipment-section equipment-section--modifiers">
    <header class="tab-section-header">
      <h3 class="tab-section-title">{{localize "PMTTRPG.CombatModifiers"}}</h3>
    </header>
    <div class="combat-modifiers__grid">
      <label class="stat-field">{{localize "PMTTRPG.Att"}}
        <input type="text" value="{{system.attributes.attackModifier.value}}" data-dtype="Number" readonly tabindex="-1">
      </label>
      <label class="stat-field">{{localize "PMTTRPG.Def"}}
        <input type="text" value="{{system.attributes.blockModifier.value}}" data-dtype="Number" readonly tabindex="-1">
      </label>
      <label class="stat-field">{{localize "PMTTRPG.Evd"}}
        <input type="text" value="{{system.attributes.evadeModifier.value}}" data-dtype="Number" readonly tabindex="-1">
      </label>
    </div>
  </section>

  <section class="equipment-section equipment-section--initiative">
    <header class="tab-section-header tab-section-header--initiative">
      <h3 class="tab-section-title">{{localize "PMTTRPG.InitiativeRoll"}}</h3>
      <div class="combat-initiative__inline">
        <label class="initiative-misc" title="{{localize "PMTTRPG.InitiativeMacroMiscHint"}}">
          <span class="initiative-misc__label">{{localize "PMTTRPG.InitiativeMacroMiscShort"}}</span>
          <input type="text" value="{{flags.projectmoonttrpg.initiative.macroMisc}}" data-dtype="Number" readonly tabindex="-1" aria-label="{{localize "PMTTRPG.InitiativeMacroMisc"}}">
        </label>
        <label class="initiative-misc" title="{{localize "PMTTRPG.InitiativeManualMiscHint"}}">
          <span class="initiative-misc__label">{{localize "PMTTRPG.InitiativeManualMiscShort"}}</span>
          <input type="text" name="flags.projectmoonttrpg.initiative.manualMisc" value="{{flags.projectmoonttrpg.initiative.manualMisc}}" data-dtype="Number" {{#if locked}}readonly{{/if}} aria-label="{{localize "PMTTRPG.InitiativeManualMisc"}}">
        </label>
      </div>
      <button type="button" class="initiative-roll" data-action="initiativeRoll">{{localize "PMTTRPG.InitiativeRoll"}}</button>
    </header>
  </section>

  <section class="equipment-section equipment-section--loadout">
    <header class="tab-section-header">
      <h3 class="tab-section-title">{{localize "PMTTRPG.NpcLoadout"}}</h3>
      {{#unless locked}}
      <div class="tab-section-actions">
        <button type="button" data-action="itemCreate" data-type="weapon">{{localize "PMTTRPG.AddWeapon"}}</button>
        <button type="button" data-action="itemCreate" data-type="outfit">{{localize "PMTTRPG.AddOutfit"}}</button>
      </div>
      {{/unless}}
    </header>
    <ol class="items-list">
      {{#each loadoutWeapons as |item|}}
      {{> "systems/projectmoonttrpg/templates/sheet/npc/partials/item-row-weapon.hbs" item=item assetPath=../assetPath selects=../selects locked=../locked}}
      {{else}}
      <li class="tab-empty-item"><p class="tab-empty">{{localize "PMTTRPG.Weapons"}} — {{localize "PMTTRPG.None"}}</p></li>
      {{/each}}

      {{#each loadoutOutfits as |item|}}
      {{> "systems/projectmoonttrpg/templates/sheet/npc/partials/item-row-outfit.hbs" item=item assetPath=../assetPath selects=../selects locked=../locked}}
      {{else}}
      <li class="tab-empty-item"><p class="tab-empty">{{localize "PMTTRPG.Outfits"}} — {{localize "PMTTRPG.None"}}</p></li>
      {{/each}}
    </ol>
  </section>

  <section class="equipment-section equipment-section--skills">
    <header class="tab-section-header">
      <h3 class="tab-section-title">{{localize "PMTTRPG.Skills"}}</h3>
      {{#unless locked}}
      <button type="button" data-action="itemCreate" data-type="skill">{{localize "PMTTRPG.AddSkill"}}</button>
      {{/unless}}
    </header>
    <ol class="items-list">
      {{#each skills as |item|}}
      {{> "systems/projectmoonttrpg/templates/sheet/character/partials/item-row-skill.hbs" item=item selects=../selects}}
      {{else}}
      <li class="tab-empty-item"><p class="tab-empty">{{localize "PMTTRPG.Skills"}} — {{localize "PMTTRPG.None"}}</p></li>
      {{/each}}
    </ol>
  </section>

  <section class="equipment-section equipment-section--tools">
    <header class="tab-section-header">
      <h3 class="tab-section-title">{{localize "PMTTRPG.Tools"}}</h3>
      <div class="tab-section-header__meta inventory-slots inventory-slots--tools">
        <span class="inventory-slots__pool{{#if system.attributes.toolSlots.over}} inventory-slots__pool--over{{/if}}" title="{{localize "PMTTRPG.ToolSlots"}}">
          <span class="inventory-slots__label">{{localize "PMTTRPG.ToolSlotsUsed"}}</span>
          <span class="inventory-slots__value">{{system.attributes.toolSlots.used}} / {{system.attributes.toolSlots.value}}</span>
        </span>
        <span class="inventory-slots__pool{{#if system.attributes.narrativeSlots.over}} inventory-slots__pool--over{{/if}}" title="{{localize "PMTTRPG.NarrativeSlots"}}">
          <span class="inventory-slots__label">{{localize "PMTTRPG.NarrativeSlots"}}</span>
          <span class="inventory-slots__value">{{system.attributes.narrativeSlots.used}} / {{system.attributes.narrativeSlots.value}}</span>
        </span>
        <span class="inventory-slots__pool{{#if system.attributes.stockSlots.over}} inventory-slots__pool--over{{/if}}" title="{{localize "PMTTRPG.StockSlots"}}">
          <span class="inventory-slots__label">{{localize "PMTTRPG.StockSlots"}}</span>
          <span class="inventory-slots__value">{{system.attributes.stockSlots.used}} / {{system.attributes.stockSlots.value}}</span>
        </span>
      </div>
      {{#unless locked}}
      <button type="button" data-action="itemCreate" data-type="tool">{{localize "PMTTRPG.AddTool"}}</button>
      {{/unless}}
    </header>

    {{#if tools.length}}
    <ol class="items-list">
      {{#each tools as |tool|}}
      <li class="item item--tool collapsed{{#if tool.system.equipped}} item--equipped{{/if}}" data-item-id="{{tool._id}}">
        <div class="item-title-row">
          <div class="item-title-row__lead">
            {{> "systems/projectmoonttrpg/templates/sheet/character/partials/item-thumb.hbs" img=tool.img name=tool.name}}
            <strong class="item-name">
              {{tool.name}}
              {{#if (eq tool.system.form "reusable")}}
              <span class="item-count item-count--uses">{{tool.system.usesRemaining}}/{{tool.system.usesMax}}</span>
              {{else if (ne tool.system.quantity 1)}}
              <span class="item-count">×{{tool.system.quantity}}</span>
              {{/if}}
              {{#if (and tool.system.packing (ne tool.system.packing.accepts "none"))}}
              <span class="item-count item-count--packing"
                    title="{{localize (lookup ../selects.toolPackingTypes tool.system.packing.accepts)}}">
                {{localize "PMTTRPG.ToolPackingPacked"}} {{tool.system.packing.used}}/{{tool.system.packing.capacity}}
              </span>
              {{/if}}
            </strong>
          </div>
          <div class="item-controls">
            {{#if (eq tool.system.form "reusable")}}
            {{> "systems/projectmoonttrpg/templates/sheet/character/partials/item-controls-tool.hbs" itemId=tool._id counter="usesRemaining" equipped=tool.system.equipped handProperty=tool.system.handProperty showUse=(and (ne tool.system.toolKind "applied") (or (ne tool.system.form "none") tool.system.allowUse))}}
            {{else}}
            {{> "systems/projectmoonttrpg/templates/sheet/character/partials/item-controls-tool.hbs" itemId=tool._id counter="quantity" equipped=tool.system.equipped handProperty=tool.system.handProperty showUse=(and (ne tool.system.toolKind "applied") (or (ne tool.system.form "none") tool.system.allowUse))}}
            {{/if}}
          </div>
        </div>
        <div class="item-details">
          <div class="item-tags">
            {{#if tool.system.equipped}}
            {{#if (eq tool.system.handProperty "handless")}}
            <span class="tag tag--equipped">{{localize "PMTTRPG.ToolWorn"}}</span>
            {{else}}
            <span class="tag tag--equipped">{{localize "PMTTRPG.ToolHeld"}}</span>
            {{/if}}
            {{/if}}
            {{#if (lookup ../selects.toolForms tool.system.form)}}
            <span class="tag">{{localize (lookup ../selects.toolForms tool.system.form)}}</span>
            {{/if}}
            {{#if (lookup ../selects.toolHands tool.system.handProperty)}}
            <span class="tag">{{localize (lookup ../selects.toolHands tool.system.handProperty)}}</span>
            {{/if}}
            {{#if (lookup ../selects.toolKinds tool.system.toolKind)}}
            <span class="tag">{{localize (lookup ../selects.toolKinds tool.system.toolKind)}}</span>
            {{/if}}
            {{#if tool.system.compact}}
            <span class="tag">{{localize "PMTTRPG.ToolCompact"}}</span>
            {{else if (lookup ../selects.toolInventoryTags tool.system.inventoryTag)}}
            <span class="tag">{{localize (lookup ../selects.toolInventoryTags tool.system.inventoryTag)}}</span>
            {{/if}}
            {{#if tool.system.unique}}
            <span class="tag">{{localize "PMTTRPG.ToolUnique"}}</span>
            {{/if}}
          </div>
          {{#if tool.system.descriptionEnriched}}
          <div class="item-flavor description">{{{tool.system.descriptionEnriched}}}</div>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ol>
    {{else}}
    <p class="tab-empty">{{localize "PMTTRPG.NoTools"}}</p>
    {{/if}}
  </section>

  <section class="equipment-section equipment-section--augment">
    <header class="tab-section-header">
      <h3 class="tab-section-title">{{localize "PMTTRPG.Augment"}}</h3>
      {{#unless locked}}
        {{#unless augment}}
        <button type="button" data-action="itemCreate" data-type="augment">{{localize "PMTTRPG.AddAugment"}}</button>
        {{/unless}}
      {{/unless}}
    </header>
    <ol class="items-list">
      {{#if augment}}
      {{> "systems/projectmoonttrpg/templates/sheet/npc/partials/item-row-augment.hbs" item=augment selects=selects locked=locked}}
      {{else}}
      <li class="tab-empty-item"><p class="tab-empty">{{localize "PMTTRPG.Augment"}} — {{localize "PMTTRPG.None"}}</p></li>
      {{/if}}
    </ol>
  </section>

  <section class="equipment-section equipment-section--ammunition">
    <header class="tab-section-header">
      <h3 class="tab-section-title">{{localize "PMTTRPG.Ammunition"}}</h3>
      {{#unless locked}}
      <button type="button" data-action="itemCreate" data-type="ammunition">{{localize "PMTTRPG.AddAmmunition"}}</button>
      {{/unless}}
    </header>

    {{#if ammunition.length}}
    <ol class="items-list">
      {{#each ammunition as |ammo|}}
      <li class="item item--ammunition collapsed" data-item-id="{{ammo._id}}">
        <div class="item-title-row">
          <div class="item-title-row__lead">
            {{> "systems/projectmoonttrpg/templates/sheet/character/partials/item-thumb.hbs" img=ammo.img name=ammo.name}}
            <strong class="item-name">{{ammo.name}} <span class="item-count">×{{ammo.system.quantity}}</span></strong>
            {{#if (lookup ../selects.damageTypes ammo.system.damageType)}}
            <div class="item-title-row__actions">
              {{> "systems/projectmoonttrpg/templates/sheet/character/partials/damage-type-icon.hbs" assetPath=../assetPath damageType=ammo.system.damageType label=(localize (lookup ../selects.damageTypes ammo.system.damageType))}}
            </div>
            {{/if}}
          </div>
          <div class="item-controls">
            {{> "systems/projectmoonttrpg/templates/sheet/character/partials/item-controls-ammunition.hbs" itemId=ammo._id}}
          </div>
        </div>
        <div class="item-details">
          <div class="item-tags">
            {{#if (lookup ../selects.ammoTypes ammo.system.ammoType)}}
            <span class="tag">{{localize (lookup ../selects.ammoTypes ammo.system.ammoType)}}</span>
            {{/if}}
            {{#if (and (eq ammo.system.ammoType "specialized") (lookup ../selects.inventoryPools ammo.system.inventoryPool))}}
            <span class="tag">{{localize (lookup ../selects.inventoryPools ammo.system.inventoryPool)}}</span>
            {{/if}}
          </div>
          {{#if ammo.system.descriptionEnriched}}
          <div class="item-flavor description">{{{ammo.system.descriptionEnriched}}}</div>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ol>
    {{else}}
    <p class="tab-empty">{{localize "PMTTRPG.NoAmmunition"}}</p>
    {{/if}}
  </section>

  <section class="equipment-section equipment-section--statuses">
    <header class="tab-section-header">
      <h3 class="tab-section-title">{{localize "PMTTRPG.ActiveStatuses"}}</h3>
    </header>
    {{#if statuses.length}}
    <ol class="items-list">
      {{#each statuses as |status|}}
      <li class="item item--status collapsed" data-item-id="{{status.representative._id}}" data-status-key="{{status.key}}">
        <div class="item-title-row">
          <div class="item-title-row__lead">
            {{> "systems/projectmoonttrpg/templates/sheet/character/partials/item-thumb.hbs" img=status.img name=status.name}}
            <strong class="item-name">{{status.name}} <span class="item-count">×{{status.count}}</span></strong>
          </div>
          <div class="item-controls">
            <button type="button" class="item-control" data-action="statusControl" data-control="decrease" title='{{localize "PMTTRPG.RemoveStack"}}' aria-label='{{localize "PMTTRPG.RemoveStack"}}'><i class="fas fa-minus" aria-hidden="true"></i></button>
            <button type="button" class="item-control" data-action="statusControl" data-control="increase" title='{{localize "PMTTRPG.AddStack"}}' aria-label='{{localize "PMTTRPG.AddStack"}}'><i class="fas fa-plus" aria-hidden="true"></i></button>
            <button type="button" class="item-control" data-action="itemEdit" data-item-id="{{status.representative._id}}" title="{{localize "PMTTRPG.Common.EditItem"}}" aria-label="{{localize "PMTTRPG.Common.EditItem"}}"><i class="fas fa-edit" aria-hidden="true"></i></button>
            <button type="button" class="item-control item-toggle-details" data-action="toggleDetails" aria-expanded="false" title="{{localize "PMTTRPG.Common.Details"}}" aria-label="{{localize "PMTTRPG.Common.Details"}}"><i class="fas fa-chevron-down" aria-hidden="true"></i></button>
          </div>
        </div>
        <div class="item-details">
          {{#if status.system.descriptionEnriched}}
          <div class="item-flavor description">{{{status.system.descriptionEnriched}}}</div>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ol>
    {{else}}
    <p class="tab-empty">{{localize "PMTTRPG.NoStatuses"}}</p>
    {{/if}}
  </section>
</div>
